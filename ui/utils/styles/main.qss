    border-radius: 4px;
}

QFrame#kioskCardAccent[accent="blue"] {
    background: #2B6CB0;
}

QFrame#kioskCardAccent[accent="green"] {
    background: #2F855A;
}

QFrame#kioskCardAccent[accent="coral"] {
    background: #E76F51;
}

QFrame#kioskIconBubble {
    border-radius: 58px;
}

QFrame#kioskIconBubble[accent="blue"] {
    background: #E9F2FF;
    border: 1px solid #BBD4F2;
}

QFrame#kioskIconBubble[accent="green"] {
    background: #EAF5F2;
    border: 1px solid #BFE5D2;
}

QFrame#kioskIconBubble[accent="coral"] {
    background: #FFF0EA;
    border: 1px solid #F5C6B8;
}

QLabel#kioskActionIcon {
    color: #1E293B;
    font-size: 42px;
    font-weight: 900;
}

QLabel#kioskActionTitle {
    color: #102A27;
    font-size: 30px;
    font-weight: 900;
}

QLabel#kioskActionDesc {
    color: #64748B;
    font-size: 18px;
    font-weight: 700;
}

QPushButton#kioskGhostButton,
QPushButton#kioskSecondaryButton,
QPushButton#kioskSearchFooterButton,
QPushButton#kioskRoundIconButton {
    background: #FFFFFF;
    color: #1E293B;
    border: 1px solid #E8DED2;
    border-radius: 18px;
    font-size: 20px;
    font-weight: 900;
    padding: 12px 22px;
}

QPushButton#kioskGhostButton[accent="blue"] {
    color: #2B6CB0;
    border-color: #BBD4F2;
    background: #F5FAFF;
}

QPushButton#kioskGhostButton[accent="green"] {
    color: #2F855A;
    border-color: #BFE5D2;
    background: #F4FBF8;
}

QPushButton#kioskGhostButton[accent="coral"] {
    color: #E76F51;
    border-color: #F5C6B8;
    background: #FFF7F3;
}

QPushButton#kioskSecondaryButton {
    color: #2B6CB0;
    border-color: #BBD4F2;
    background: #F5FAFF;
}

QPushButton#kioskSearchCallButton,
QPushButton#kioskConfirmationSecondaryButton,
QPushButton#kioskProgressPrimaryButton {
    background: #FFF0EA;
    color: #B9472B;
    border: 1px solid #F5C6B8;
    border-radius: 18px;
    font-size: 21px;
    font-weight: 900;
    padding: 14px 24px;
}

QFrame#kioskFooterBar,
QFrame#kioskSearchBottomBar,
QFrame#kioskConfirmationBottomBar {
    background: #FFFFFF;
    border-top: 1px solid #E8DED2;
}

QFrame#kioskFooterStat {
