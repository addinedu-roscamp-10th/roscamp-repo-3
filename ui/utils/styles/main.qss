    font-size: 16px;
    font-weight: 900;
    padding: 8px 16px;
}

QLabel#kioskHeroTitle {
    color: #102A27;
    font-size: 52px;
    font-weight: 900;
}

QLabel#kioskHeroDesc {
    color: #64748B;
    font-size: 22px;
    font-weight: 700;
}

QFrame#kioskActionCard {
    background: #FFFFFF;
    border: 1px solid #E8DED2;
    border-radius: 28px;
}

QFrame#kioskActionCard[accent="blue"] {
    border-color: #BBD4F2;
}

QFrame#kioskActionCard[accent="green"] {
    border-color: #BFE5D2;
}

QFrame#kioskActionCard[accent="coral"] {
    border-color: #F5C6B8;
}

QFrame#kioskCardAccent {
